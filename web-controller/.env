# YeeSite + OLA stack configuration
# Copy to .env and edit — docker-compose picks this up automatically

# ── OLA (Open Lighting Architecture) ────────────────────────────────────────
OLA_HOST=ola
OLA_PORT=9090
# Host path for OLA config persistence (bind-mounted into the container)
OLA_CONFIG_DIR=./ola-config

# ── DMX / Fixture ────────────────────────────────────────────────────────────
DMX_UNIVERSE=1
# IP of the ArtNet DMX interface (eDMX1-PRO)
ARTNET_IP=10.0.15.109

# ── Web controller ───────────────────────────────────────────────────────────
WEB_PORT=5003
FPS=60

# ── RTP-MIDI ─────────────────────────────────────────────────────────────────
RTPMIDI_CONTROL_PORT=5004
RTPMIDI_DATA_PORT=5005
